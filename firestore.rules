rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Allow read access to all users (public blog)
    match /{document=**} {
      allow read: if true;
    }

    // Restrict write access to authenticated admin users only
    match /{document=**} {
      allow write: if request.auth != null;
    }
  }
}
